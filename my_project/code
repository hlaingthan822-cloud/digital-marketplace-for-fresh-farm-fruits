  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  background: white;
  padding: 20px;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
}

/* Dashboard Grid ခွဲခြင်း (ဖောင်က တစ်ဖက်၊ စာရင်းက တစ်ဖက်) */
.grid-cols-1.md\:grid-cols-3 {
  display: grid;
  grid-template-columns: 1fr 2fr; /* ဖောင်ကို ၁ ဆ၊ စာရင်းကို ၂ ဆ နေရာပေးခြင်း */
  gap: 30px;
  align-items: start;
}

/* သီးနှံအသစ်တင်သည့် Form Box */
.bg-white.p-6.rounded-2xl.border {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
}

.bg-white.p-6.rounded-2xl.border h2 {
  color: #2e7d32;
  font-size: 1.25rem;
  margin-bottom: 20px;
  border-bottom: 2px solid #e8f5e9;
  padding-bottom: 10px;
}

/* Input ကွက်တိများကို လှပအောင် ပြင်ဆင်ခြင်း */
.space-y-3 input {
  width: 100%;
  padding: 12px;
  border: 1px solid #cbd5e0;
  border-radius: 8px;
  font-size: 0.95rem;
  margin-bottom: 15px; /* Input တစ်ခုချင်းစီကြား ခြားရန် */
  transition: border-color 0.2s;
  display: block;
}

.space-y-3 input:focus {
  outline: none;
  border-color: #2e7d32;
  box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.1);
}

/* တင်သွင်းမည် ခလုတ် */
.space-y-3 button {
  width: 100%;
  background-color: #2e7d32;
  color: white;
  border: none;
  padding: 14px;
  border-radius: 8px;
  font-weight: 600;
  font-size: 1rem;
  cursor: pointer;
  transition: background 0.2s;
}

.space-y-3 button:hover {
  background-color: #1b5e20;
}

/* ရောင်းချနေဆဲ သီးနှံများစာရင်း Box */
.divide-y {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.py-3.flex.justify-between.items-center {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8fafc;
  padding: 16px 20px;
  border-radius: 10px;
  border: 1px solid #edf2f7;
}

.py-3.flex.justify-between.items-center span:first-child {
  font-weight: 500;
  color: #2d3748;
}

/* Status Badge လေးများ (ပစ္စည်းရှိ/အရောင်းသွက်) */
.text-xs.bg-green-100 {
  background-color: #e8f5e9;
  color: #1b5e20;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
}

.text-xs.bg-gray-100 {
  background-color: #edf2f7;
  color: #4a5568;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
}
/* Login Page Layout ပြင်ဆင်ခြင်း */
.min-h-screen.flex.items-center.justify-center {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.max-w-md.w-full.bg-white {
  background: white;
  max-width: 420px;
  width: 100%;
  padding: 40px 30px;
  border-radius: 16px;
  border: 1px solid #e2e8f0;
  box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
}

.max-w-md.w-full.bg-white h1 {
  color: #1b5e20;
  font-size: 1.8rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
}

.max-w-md.w-full.bg-white p.text-center {
  color: #718096;
  font-size: 0.9rem;
  text-align: center;
  margin-bottom: 24px;
}

/* Login Form Inputs */
form.space-y-4 div {
  margin-bottom: 20px;
}

form.space-y-4 label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  color: #4a5568;
  margin-bottom: 8px;
}

form.space-y-4 input {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid #cbd5e0;
  border-radius: 10px;
  font-size: 0.95rem;
  transition: border-color 0.2s;
}

form.space-y-4 input:focus {
  outline: none;
  border-color: #2e7d32;
}

/* Login Button */
form.space-y-4 button {
  width: 100%;
  background-color: #2e7d32;
  color: white;
  border: none;
  padding: 14px;
  border-radius: 10px;
  font-weight: 600;
  font-size: 1rem;
  cursor: pointer;
  margin-top: 10px;
  transition: background 0.2s;
}

form.space-y-4 button:hover {
  background-color: #1b5e20;
}

/* Product Card အတွင်း ပုံစတိုင်အသစ် */
.fruit-img-box {
