                      onClick={() => handleQuickAdd(fruit)}
                      style={{
                        width: "100%",
                        backgroundColor: "#2e7d32",
                        color: "white",
                        border: "none",
                        padding: "6px",
                        borderRadius: "6px",
                        fontSize: "0.8rem",
                        cursor: "pointer",
                      }}
                    >
                      + ထည့်မည်
                    </button>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* ညာဘက်ခြမ်း: မှာယူသူအချက်အလက်နှင့် ငွေချေစနစ်ရွေးချယ်ခြင်း */}
