datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String
  role     String  @default("CUSTOMER") // "FARMER" သို့မဟုတ် "CUSTOMER"
  orders   Order[]
}

model Product {
  id        String      @id @default(uuid())
  name      String
  price     Int
  farmer    String
  image     String?
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model Order {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  name      String?     // ? ထည့်ပြီး optional ဖြစ်အောင် လုပ်သည်
  phone     String?
  address   String?
  total     Int         @default(0) // default value ပေးထားသည်
  createdAt DateTime    @default(now())
  items     OrderItem[]
}
model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
}